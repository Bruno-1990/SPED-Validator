# Copie para `.env.local` e use a MESMA chave que `API_KEY` no `.env` do backend.
# Sem isso, o bundle continua com a chave de desenvolvimento embutida e parece
# que "o frontend não mudou" quando você altera só o servidor.
VITE_API_KEY=

# Opcional — default `/api` (compatível com proxy do Vite).
# VITE_API_BASE=/api
